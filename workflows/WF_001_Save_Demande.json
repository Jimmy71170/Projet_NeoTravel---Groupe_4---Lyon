        "jsCode": "// =======================================\n// Save_Demande\n// Retour erreur Airtable\n// Version : MVP 1.2\n// =======================================\n\nconst now = new Date().toISOString();\n\nlet normalized = {};\n\ntry {\n  normalized = $(\"Normalize_Input_WF001\").first()?.json || {};\n} catch (error) {\n  normalized = {};\n}\n\nconst context = normalized.context || {};\nconst inputError = $input.first()?.json || {};\n\nreturn [\n  {\n    json: {\n      success: false,\n      message: \"Impossible de créer la demande dans Airtable.\",\n      error: \"AIRTABLE_CREATE_FAILED\",\n      details: inputError.error?.message || inputError.message || null,\n      context: {\n        ...context,\n        last_tool: \"Save_Demande\",\n        last_error_at: now\n      }\n    }\n  }\n];"
