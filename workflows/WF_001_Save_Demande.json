        "jsCode": "// =======================================\n// WF_001_Update_Client\n// Retour du Tool\n// Version : 3.0\n// Contrat de sortie standard NeoTravel\n// =======================================\n\nconst now = new Date().toISOString();\n\nconst airtable = $input.first()?.json || {};\nconst normalized = $(\"Normalize_Input_WF001\").first()?.json || {};\n\nconst context = normalized.context || {};\n\nconst demandeRecordId = airtable.id || null;\nconst demandeId = airtable.fields?.[\"Demande ID\"] || context.demande_id || null;\n\nconst updatedContext = {\n  ...context,\n\n  demande_id: demandeId,\n\n  airtable: {\n    ...(context.airtable || {}),\n    demande_record_id: demandeRecordId\n  },\n\n  client: {\n    ...(context.client || {}),\n    saved: true,\n    saved_at: now\n  },\n\n  trajet: {\n    ...(context.trajet || {}),\n    saved: true,\n    saved_at: now\n  },\n\n  last_tool: \"WF_001_Update_Client\",\n  last_update_at: now\n};\n\nreturn [\n  {\n    json: {\n\n      // =======================================\n      // Contrat standard\n      // =======================================\n\n      success: true,\n\n      status: \"CLIENT_UPDATED\",\n\n      tool: \"WF_001_Update_Client\",\n\n      version: \"3.0\",\n\n      timestamp: now,\n\n      context: updatedContext,\n\n      message: \"Les informations du client et de la demande ont été enregistrées.\",\n\n      next_action: \"call_tool\",\n\n      next_workflow: \"WF_003_Update_Trajet\",\n\n      next_payload: {\n        context: updatedContext\n      },\n\n      error: null\n\n    }\n  }\n];"
      },
