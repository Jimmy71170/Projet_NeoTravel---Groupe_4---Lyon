      "parameters": {
        "jsCode": "// =======================================\n// WF_001_Update_Client\n// Normalize_Input_WF001\n// Version : 3.0\n// Compatible avec l'AI Agent NeoTravel\n// =======================================\n\nconst raw = $input.first()?.json || {};\nconst now = new Date().toISOString();\n\nfunction clean(value) {\n  if (value === undefined || value === null) return null;\n  const str = String(value).trim();\n  return str.length ? str : null;\n}\n\nfunction parseIfJson(value) {\n  if (typeof value !== \"string\") return value;\n\n  try {\n    return JSON.parse(value);\n  } catch {\n    return value;\n  }\n}\n\n// ---------------------------------------\n// Lecture de l'entrée\n// ---------------------------------------\n\nlet input = raw;\n\nif (typeof raw.query === \"string\") {\n  input = parseIfJson(raw.query);\n}\n\nif (typeof raw.input === \"string\") {\n  input = parseIfJson(raw.input);\n}\n\nif (raw.input && typeof raw.input === \"object\") {\n  input = raw.input;\n}\n\nif (typeof input === \"string\") {\n  return [{\n    json: {\n      success: false,\n      message: \"Impossible de parser l'entrée.\",\n      context: {}\n    }\n  }];\n}\n\n// ---------------------------------------\n// Compatibilité ancien / nouveau format\n// ---------------------------------------\n\nconst rootClient = input.client || input.context || input;\nconst rawTrajet = input.trajet || {};\nconst rawVehicule = input.vehicule || {};\n\n// ---------------------------------------\n// Client\n// ---------------------------------------\n\nconst client = {\n\n  type_client:\n    clean(rootClient.type_client) ||\n    clean(rootClient.client_type) ||\n    clean(rootClient.customer_type),\n\n  nom:\n    clean(rootClient.nom),\n\n  prenom:\n    clean(rootClient.prenom),\n\n  email:\n    clean(rootClient.email)?.toLowerCase() || null,\n\n  telephone:\n    clean(rootClient.telephone),\n\n  entreprise:\n    clean(rootClient.entreprise) ||\n    clean(rootClient.organisation) ||\n    clean(rootClient.organization) ||\n    clean(rootClient.societe)\n\n};\n\n// ---------------------------------------\n// Trajet\n// ---------------------------------------\n\nconst trajet = {\n\n  depart:\n    clean(rawTrajet.depart) ||\n    clean(rawTrajet.ville_depart) ||\n    clean(rawTrajet.depart_ville),\n\n  destination:\n    clean(rawTrajet.destination) ||\n    clean(rawTrajet.ville_destination) ||\n    clean(rawTrajet.destination_ville),\n\n  depart_adresse:\n    clean(rawTrajet.depart_adresse),\n\n  destination_adresse:\n    clean(rawTrajet.destination_adresse),\n\n  date_depart:\n    clean(rawTrajet.date_depart),\n\n  date_retour:\n    clean(rawTrajet.date_retour),\n\n  nb_passagers:\n    Number(\n      rawTrajet.nb_passagers ??\n      rawTrajet.nombre_passagers\n    ) || null,\n\n  type_trajet:\n    clean(rawTrajet.type_trajet),\n\n  type_vehicule:\n    clean(rawTrajet.type_vehicule) ||\n    clean(rawTrajet.type_vehicule_souhaite) ||\n    clean(rawVehicule.type),\n\n  bagages_par_personne:\n    clean(input.bagages) ||\n    clean(rawTrajet.bagages) ||\n    clean(rawTrajet.bagages_par_personne),\n\n  options:\n    Array.isArray(input.options)\n      ? input.options\n      : Array.isArray(rawTrajet.options)\n      ? rawTrajet.options\n      : [],\n\n  commentaire:\n    clean(input.commentaire) ||\n    clean(rawTrajet.commentaire),\n\n  urgence:\n    clean(input.urgence) ||\n    clean(rawTrajet.urgence),\n\n  date_demande:\n    clean(rawTrajet.date_demande) ||\n    now.slice(0,10)\n\n};\n\n// ---------------------------------------\n// Déductions\n// ---------------------------------------\n\nif (!trajet.type_trajet) {\n\n  trajet.type_trajet = trajet.date_retour\n    ? \"Aller-retour\"\n    : \"Aller simple\";\n\n}\n\n// ---------------------------------------\n// Contexte\n// ---------------------------------------\n\nconst context = {\n\n  client,\n\n  trajet,\n\n  raw_user_message:\n    typeof raw.query === \"string\"\n      ? raw.query\n      : JSON.stringify(input),\n\n  last_tool: \"Normalize_Input_WF001\",\n\n  last_update_at: now\n\n};\n\n// ---------------------------------------\n// Retour\n// ---------------------------------------\n\nreturn [\n{\njson:{\n\nsuccess:true,\n\nmessage:\"Entrée Save_Demande normalisée.\",\n\ncontext\n\n}\n}\n];"
      },
