      "parameters": {
        "jsCode": "// =======================================\n// Calculate_Distance\n// Tag geocode depart\n// Version : MVP 1.0\n// =======================================\n\nconst geocodeDepart = $input.first()?.json || {};\nconst normalized = $(\"Normalize_Input_WF003\").first()?.json || {};\n\nreturn [\n  {\n    json: {\n      ...normalized,\n      geocode_depart: geocodeDepart\n    }\n  }\n];"
      },
