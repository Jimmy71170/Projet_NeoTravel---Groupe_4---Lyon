    {
      "parameters": {
        "jsCode": "// =======================================\n// Calculate_Distance\n// Normalize_Input_WF003\n// Version : MVP 1.1\n// Entrée attendue : { context: {...} }\n// =======================================\n\nconst input = $input.first()?.json || {};\nconst now = new Date().toISOString();\n\nfunction clean(value) {\n  if (value === undefined || value === null) return null;\n  const str = String(value).trim();\n  return str.length > 0 ? str : null;\n}\n\nconst context = input.context || {};\nconst trajet = context.trajet || {};\n\nconst depart =\n  clean(trajet.adresse_depart) ||\n  clean(trajet.depart) ||\n  clean(trajet.ville_depart);\n\nconst destination =\n  clean(trajet.adresse_arrivee) ||\n  clean(trajet.destination) ||\n  clean(trajet.ville_arrivee);\n\nconst updatedContext = {\n  ...context,\n  last_update_at: now\n};\n\nreturn [\n  {\n    json: {\n      success: true,\n      message: \"Entrée Calculate_Distance normalisée.\",\n      context: updatedContext,\n      lookup: {\n        depart,\n        destination\n      }\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -288,
        192
      ],
      "id": "83487bd0-34b5-4eeb-8247-079319d55fb2",
      "name": "Normalize_Input_WF003"
    },
    {
      "parameters": {
        "jsCode": "// =======================================\n// Calculate_Distance\n// Prepare_Route_Request\n// Version : MVP 1.1\n// =======================================\n\nconst items = $input.all().map(item => item.json);\nconst now = new Date().toISOString();\n\nconst base = items.find(i => i.context) || {};\nconst departItem = items.find(i => i.geocode_depart);\nconst destinationItem = items.find(i => i.geocode_destination);\n\nconst context = {\n  ...(base.context || {}),\n  last_update_at: now\n};\n\nconst departFeature = departItem?.geocode_depart?.features?.[0] || null;\nconst destinationFeature = destinationItem?.geocode_destination?.features?.[0] || null;\n\nconst departCoords = departFeature?.geometry?.coordinates || null;\nconst destinationCoords = destinationFeature?.geometry?.coordinates || null;\n\nif (!departCoords || !destinationCoords) {\n  return [\n    {\n      json: {\n        success: false,\n        message: \"Impossible de géocoder le départ ou la destination.\",\n        error: \"GEOCODING_FAILED\",\n        context: {\n          ...context,\n          last_tool: \"Calculate_Distance\",\n          last_error_at: now\n        }\n      }\n    }\n  ];\n}\n\nreturn [\n  {\n    json: {\n      success: true,\n      message: \"Coordonnées prêtes pour le calcul de distance.\",\n      context,\n      geocoding: {\n        depart: {\n          label: departFeature.properties?.label || null,\n          coordinates: departCoords\n        },\n        destination: {\n          label: destinationFeature.properties?.label || null,\n          coordinates: destinationCoords\n        }\n      },\n      ors_body: {\n        coordinates: [\n          departCoords,\n          destinationCoords\n        ]\n      }\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        672,
