    {
      "parameters": {
        "jsCode": "// =======================================\n// WF_005_Calculate_Distance\n// Retour du Tool\n// Version : 3.0\n// Contrat de sortie standard NeoTravel\n// =======================================\n\nconst now = new Date().toISOString();\n\nconst routeOutput = $(\"HTTP Request\").first()?.json || {};\nconst prepared = $(\"Prepare_Route_Request\").first()?.json || {};\n\nconst context = prepared.context || {};\nconst geocoding = prepared.geocoding || {};\n\nconst route = routeOutput.routes?.[0] || null;\nconst summary = route?.summary || {};\n\nconst distanceMeters = Number(summary.distance || 0);\nconst durationSeconds = Number(summary.duration || 0);\n\nconst distanceKm = distanceMeters > 0\n  ? Math.round((distanceMeters / 1000) * 10) / 10\n  : null;\n\nconst dureeHeures = durationSeconds > 0\n  ? Math.round((durationSeconds / 3600) * 100) / 100\n  : null;\n\n// =======================================\n// Erreur\n// =======================================\n\nif (!distanceKm || !dureeHeures) {\n\n  const errorContext = {\n    ...context,\n    last_tool: \"WF_005_Calculate_Distance\",\n    last_error_at: now\n  };\n\n  return [\n    {\n      json: {\n\n        success: false,\n\n        status: \"ERROR\",\n\n        tool: \"WF_005_Calculate_Distance\",\n\n        version: \"3.0\",\n\n        timestamp: now,\n\n        context: errorContext,\n\n        message: \"Impossible de calculer automatiquement la distance entre les deux adresses.\",\n\n        next_action: \"error\",\n\n        next_workflow: \"\",\n\n        next_payload: {},\n\n        error: {\n          code: \"ROUTE_NOT_FOUND\",\n          details: \"Aucun itinéraire valide n'a été retourné par OpenRouteService.\"\n        }\n\n      }\n    }\n  ];\n}\n\n// =======================================\n// Mise à jour du contexte\n// =======================================\n\nconst updatedContext = {\n\n  ...context,\n\n  distance: {\n\n    calculated: true,\n\n    distance_km: distanceKm,\n\n    duree_heures: dureeHeures,\n\n    duration_seconds: durationSeconds,\n\n    distance_meters: distanceMeters,\n\n    provider: \"openrouteservice\",\n\n    geocoding,\n\n    calculated_at: now\n\n  },\n\n  trajet: {\n\n    ...(context.trajet || {}),\n\n    distance_km: distanceKm,\n\n    duree_heures: dureeHeures\n\n  },\n\n  last_tool: \"WF_005_Calculate_Distance\",\n\n  last_update_at: now\n\n};\n\n// =======================================\n// Retour Tool\n// =======================================\n\nreturn [\n  {\n    json: {\n\n      success: true,\n\n      status: \"DISTANCE_CALCULATED\",\n\n      tool: \"WF_005_Calculate_Distance\",\n\n      version: \"3.0\",\n\n      timestamp: now,\n\n      context: updatedContext,\n\n      message: \"La distance et la durée du trajet ont été calculées avec succès.\",\n\n      next_action: \"call_tool\",\n\n      next_workflow: \"WF_006_Calculate_Quote\",\n\n      next_payload: {\n        context: updatedContext\n      },\n\n      error: null\n\n    }\n  }\n];"
      },
