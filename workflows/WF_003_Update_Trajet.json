      "name": "Tag geocode depart"
    },
    {
      "parameters": {
        "jsCode": "// =======================================\n// Calculate_Distance\n// Tag geocode destination\n// Version : MVP 1.0\n// =======================================\n\nconst geocodeDestination = $input.first()?.json || {};\nconst normalized = $(\"Normalize_Input_WF003\").first()?.json || {};\n\nreturn [\n  {\n    json: {\n      ...normalized,\n      geocode_destination: geocodeDestination\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
